# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the client. Used by sync/admin routes.
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar (service account JSON, base64-encoded; Phase 3). One
# calendar per school is discovered from the service account's calendarList —
# GOOGLE_CALENDAR_ID is obsolete (multi-calendar sync); share every school's
# calendar with the service account's email instead of setting a single ID.
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
# Random shared secret for pg_cron → calendar-sync Edge Function (Phase 3).
# Set the same value as an Edge secret and a Supabase Vault secret; never expose it to clients.
CALENDAR_SYNC_SECRET=

# Web Push VAPID keys (npx web-push generate-vapid-keys; Phase 7)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.org

# Resend (email backup + Supabase custom SMTP; Phase 7)
RESEND_API_KEY=

# Zoho feedback form (Phase 4 rework): the class-feedback form lives in Zoho,
# embedded in the app as an iframe; Zoho's own webhook (not the client) closes
# the attendance session. One fixed form URL for every class (same link
# already embedded in every calendar event's description). See NEXT_STEPS.md
# for the exact Zoho-side setup.
# Public embed URL of the Zoho form (no query string).
ZOHO_FEEDBACK_FORM_URL=
# Field Link Names in the Zoho form builder — must match exactly, or leave
# unset to use the defaults shown (session_id / school / teacher / date /
# class / rating / summary / challenges / students_present). school/teacher/
# date/class are prefilled automatically from the class being clocked into;
# the teacher only fills in rating/summary/challenges/students_present.
ZOHO_FEEDBACK_FIELD_SESSION=
ZOHO_FEEDBACK_FIELD_SCHOOL=
ZOHO_FEEDBACK_FIELD_TEACHER=
ZOHO_FEEDBACK_FIELD_DATE=
ZOHO_FEEDBACK_FIELD_CLASS=
ZOHO_FEEDBACK_FIELD_RATING=
ZOHO_FEEDBACK_FIELD_SUMMARY=
ZOHO_FEEDBACK_FIELD_CHALLENGES=
ZOHO_FEEDBACK_FIELD_STUDENTS_PRESENT=
# Shared secret: set the same value as a Custom Header named
# x-zoho-feedback-secret on the Zoho webhook config.
ZOHO_FEEDBACK_WEBHOOK_SECRET=

# Zoho feedback push (Phase 9) — likely obsolete now that feedback originates
# in Zoho itself rather than being pushed there after the fact; kept until
# that's confirmed. See DECISIONS.md.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
